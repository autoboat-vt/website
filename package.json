{
    "name": "autoboat-website",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "description": "Website for the AutoBoat project at Virginia Tech",
    "scripts": {
        "dev": "vite",
        "build": "vite build && node scripts/spa-fallback.mjs",
        "preview": "vite preview",
        "test": "jest",
        "test:watch": "jest --watch",
        "lint": "biome lint --config-path=./biome.json .",
        "format": "biome format --config-path=./biome.json --write .",
        "check": "biome check --config-path=./biome.json .",
        "check:write": "biome check --config-path=./biome.json --write ."
    },
    "dependencies": {
        "lucide-react": "latest",
        "react": "latest",
        "react-dom": "latest",
        "react-icons": "latest",
        "react-router-dom": "latest"
    },
    "devDependencies": {
        "@biomejs/biome": "latest",
        "@swc/core": "latest",
        "@swc/jest": "latest",
        "@tailwindcss/vite": "latest",
        "@testing-library/jest-dom": "latest",
        "@testing-library/react": "latest",
        "@types/jest": "latest",
        "@types/node": "latest",
        "@types/react": "latest",
        "@types/react-dom": "latest",
        "@vitejs/plugin-react": "latest",
        "jest": "latest",
        "jest-environment-jsdom": "latest",
        "tailwindcss": "latest",
        "typescript": "latest",
        "vite": "latest"
    },
    "optionalDependencies": {
        "@types/bun": "latest",
        "bun": "latest"
    }
}
